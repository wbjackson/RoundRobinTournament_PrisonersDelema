<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="SITS_sprint3.TournamentsViewController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 24px;" text="Connect to Server" />

    <HBox spacing="10">
        <TextField fx:id="ipField" promptText="IP Address" />
        <TextField fx:id="portField" promptText="Port" />
        <Button fx:id="connectButton" onAction="#handleConnect" text="Connect" />
    </HBox>

    <Label style="-fx-font-size: 20px;" text="Available Tournaments" />

    <!-- 🔥 THIS IS THE IMPORTANT PART -->
    <ListView fx:id="tournamentList" VBox.vgrow="ALWAYS" />

    <Button fx:id="refreshbutton" onAction="#handleRefresh" text="Refresh" />

</VBox>
