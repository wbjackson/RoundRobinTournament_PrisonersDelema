<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="SITS_sprint3.MoveViewController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 36px; -fx-font-weight: bold;" text="Move View" />

    <Label fx:id="tournamentTitleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Tournament: Selected Tournament" />

    <HBox spacing="30.0" VBox.vgrow="ALWAYS">

        <VBox prefWidth="220.0" spacing="12.0">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Players:" />
            <ListView fx:id="playerList" prefHeight="140.0" />

            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Current Scores:" />
            <ListView fx:id="scoreList" prefHeight="140.0" />

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="exitButton" onAction="#handleExit" prefHeight="45.0" prefWidth="160.0" text="Exit Tournament" />
        </VBox>

        <VBox spacing="12.0" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Live Moves" />
            <ListView fx:id="moveList" prefHeight="350.0" VBox.vgrow="ALWAYS" />
        </VBox>

    </HBox>

</VBox>
