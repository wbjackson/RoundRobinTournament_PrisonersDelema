<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="450.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="SITS_sprint3.TournamentsViewController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Connect to Server:" />

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label style="-fx-font-size: 18px;" text="IP:" />
        <TextField fx:id="ipField" prefWidth="140.0" promptText="Enter IP" />

        <Label style="-fx-font-size: 18px;" text="Port:" />
        <TextField fx:id="portField" prefWidth="100.0" promptText="Enter Port" />

        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="connectButton" onAction="#handleConnect" prefHeight="45.0" prefWidth="130.0" text="Connect" />
    </HBox>

    <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Available Tournaments:" />

    <ListView fx:id="tournamentList" prefHeight="250.0" VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="viewTournamentButton" onAction="#handleSelectTournament" prefHeight="40.0" prefWidth="160.0" text="View Tournament" />
        <Button fx:id="refreshButton" onAction="#handleRefresh" prefHeight="40.0" prefWidth="120.0" text="Refresh" />
    </HBox>

</VBox>
